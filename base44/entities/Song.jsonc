{
  "name": "Song",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "album": {
      "type": "string"
    },
    "track_number": {
      "type": "number"
    },
    "theme": {
      "type": "string"
    },
    "lyrics": {
      "type": "string"
    },
    "suno_prompt": {
      "type": "string"
    },
    "style": {
      "type": "string"
    },
    "mood": {
      "type": "string"
    },
    "hook_line": {
      "type": "string"
    },
    "backstory": {
      "type": "string"
    },
    "production_notes": {
      "type": "string"
    },
    "scripture_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "complete",
        "exported",
        "published"
      ],
      "default": "draft"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "title"
  ]
}