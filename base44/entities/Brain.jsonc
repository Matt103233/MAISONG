{
  "name": "Brain",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "chat",
        "journal",
        "manual"
      ],
      "default": "manual"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "title",
    "content"
  ]
}